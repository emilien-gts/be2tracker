{% extends 'base.html.twig' %}

{% block title %}Bankroll{% endblock %}

{% block body %}
    <div class="container mx-auto p-5">
        <!-- Title and Add Button -->
        <div class="flex items-center pb-4 mb-3">
            <h1 class="text-2xl font-semibold text-pink-500">My bankrolls</h1>
            <div class="ml-auto"></div>
                <a
                    class="inline-block rounded-full border border-indigo-600 bg-pink-500 p-3 text-white hover:bg-transparent hover:text-indigo-600 focus:outline-none focus:ring active:text-indigo-500"
                    href="{{ path('app_bankroll_new') }}"
                >
                    {{ ux_icon('heroicons:plus', {width: '1.25rem', height: '1.25rem'}) }}
                </a>
        </div>

        <!-- Cards for Each Bankroll -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            {% for bankroll in bankrolls %}
                <article class="rounded-lg border border-gray-100 bg-white p-6">
                    <div>
                        <p class="text-sm text-gray-500">
                            <a href="{{ path('app_bankroll_show', {id: bankroll.id}) }}">{{ bankroll.name }}</a>
                        </p>
                        <p class="text-2xl font-medium text-gray-900">$240.94</p>
                    </div>

                    <div class="mt-1 flex gap-1 text-green-600">
                        {{ ux_icon('heroicons:arrow-trending-up', {class: 'size-4'}) }}
                        <p class="flex gap-2 text-xs">
                            <span class="font-medium"> 67.81% </span>
                        </p>
                    </div>
                </article>
            {% endfor %}
        </div>
    </div>
{% endblock %}
