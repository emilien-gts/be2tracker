{% extends 'base.html.twig' %}

{% block title %}Bankroll{% endblock %}

{% block body %}
    <div class="container mx-auto p-5">
        <!-- Title and Add Button -->
        <div class="flex items-center pb-4 mb-3">
            <h1 class="text-2xl font-semibold text-pink-500">{{ bankroll.name }}</h1>
            <div class="ml-auto"></div>
            <a
                class="inline-block rounded-full border border-indigo-600 bg-pink-500 p-3 text-white hover:bg-transparent hover:text-indigo-600 focus:outline-none focus:ring active:text-indigo-500"
                href="{{ path('app_bettingslip_chosetype') }}"
            >
                {{ ux_icon('heroicons:ticket', {width: '1.25rem', height: '1.25rem'}) }}
            </a>
        </div>

        <div class="grid grid-cols-1 gap-4 lg:grid-cols-4 lg:gap-8 mb-5">
            <div class="h-32 rounded-lg">
                <article
                    class="h-32 flex items-center gap-4 rounded-lg border border-gray-100 bg-white p-6 sm:justify-between"
                >
  <span class="rounded-full bg-blue-100 p-3 text-blue-600 sm:order-last mb-4">
        {{ ux_icon('heroicons:ticket', {class: 'size-8'}) }}
  </span>

                    <div>
                        <p class="text-2xl font-medium text-gray-900">{{ bankroll.bettingSlips|length }}</p>

                        <p class="text-sm text-gray-500">Total bets</p>
                    </div>
                </article>
            </div>
            <div class="h-32 rounded-lg bg-gray-200">
            </div>
            <div class="h-32 rounded-lg bg-gray-200"></div>
            <div class="h-32 rounded-lg bg-gray-200"></div>
        </div>
        <div class="h-[calc(100vh-40vh)]">
            {{ render_chart(chart) }}
        </div>

    </div>
{% endblock %}
